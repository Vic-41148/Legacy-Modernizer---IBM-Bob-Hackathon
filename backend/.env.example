# Backend Server Configuration
PORT=3001
NODE_ENV=development

# File Upload Settings
MAX_FILE_SIZE=100MB
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30000

# Bob AI Configuration
BOB_EXECUTABLE_PATH=../bob
BOB_TIMEOUT=3600000

# Session Settings
SESSION_CLEANUP_INTERVAL=3600000
MAX_CONCURRENT_SESSIONS=10