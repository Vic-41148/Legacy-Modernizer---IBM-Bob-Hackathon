# =============================================
# ModernizeAI — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ------- BACKEND -------

# Port the Express backend server listens on.
# Default: 3001
PORT=3001

# Absolute path to the IBM Bob IDE binary.
# Linux default: /usr/share/bobide/bin/bobide
# macOS default: /Applications/BobIDE.app/Contents/MacOS/bobide
# Windows default: C:\Program Files\IBM\bobide\bin\bobide.exe
BOB_BINARY_PATH=/usr/share/bobide/bin/bobide

# ------- FRONTEND (Vite) -------
# All frontend env vars MUST be prefixed with VITE_

# Base URL of the backend REST API.
# Used by DemoPage.jsx to make API calls.
# Default: http://localhost:3001
VITE_API_URL=http://localhost:3001

# Base URL of the backend WebSocket server.
# Used by DemoPage.jsx for real-time streaming.
# Default: ws://localhost:3001
VITE_WS_URL=ws://localhost:3001
